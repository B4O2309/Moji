{
  "openapi": "3.0.0",
  "info": {
    "title": "Verdi Chat API",
    "version": "1.0.0",
    "description": "Complete documentation for Verdi Real-Time Chat Application endpoints."
  },
  "servers": [
    {
      "url": "http://localhost:5001/api",
      "description": "Development server"
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "paths": {
    "/auth/signup": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Register a new user",
        "responses": { "201": { "description": "Success" } }
      }
    },
    "/auth/signin": {
      "post": {
        "tags": ["Authentication"],
        "summary": "User login",
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/auth/signout": {
      "post": {
        "tags": ["Authentication"],
        "summary": "User logout",
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/auth/refresh": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Refresh access token",
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/auth/forgot-password": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Request password reset OTP",
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/auth/verify-otp": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Verify OTP for password reset",
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/auth/reset-password": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Set new password using verified OTP",
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/auth/delete-account": {
      "delete": {
        "tags": ["Authentication"],
        "summary": "Permanently delete user account",
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/auth/sessions": {
      "get": {
        "tags": ["Authentication"],
        "summary": "Get all active login sessions",
        "responses": { "200": { "description": "Success" } }
      },
      "delete": {
        "tags": ["Authentication"],
        "summary": "Revoke all sessions (Logout from everywhere)",
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/auth/sessions/{sessionId}": {
      "delete": {
        "tags": ["Authentication"],
        "summary": "Revoke a specific session",
        "parameters": [{ "name": "sessionId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/auth/google": {
      "get": {
        "tags": ["Authentication"],
        "summary": "Initiate Google OAuth flow",
        "responses": { "302": { "description": "Redirect to Google" } }
      }
    },
    "/users/me": {
      "get": {
        "tags": ["Users"],
        "summary": "Get current user profile",
        "responses": { "200": { "description": "Success" } }
      },
      "put": {
        "tags": ["Users"],
        "summary": "Update personal profile",
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/users/me/online-status": {
      "put": {
        "tags": ["Users"],
        "summary": "Toggle online visibility status",
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/users/me/change-password": {
      "put": {
        "tags": ["Users"],
        "summary": "Change account password",
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/users/search": {
      "get": {
        "tags": ["Users"],
        "summary": "Search users by username",
        "parameters": [{ "name": "q", "in": "query", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/users/uploadAvatar": {
      "post": {
        "tags": ["Users"],
        "summary": "Upload profile avatar",
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/users/{id}": {
      "get": {
        "tags": ["Users"],
        "summary": "Get user by ID",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/conversations": {
      "get": {
        "tags": ["Conversations"],
        "summary": "Get all active conversations",
        "responses": { "200": { "description": "Success" } }
      },
      "post": {
        "tags": ["Conversations"],
        "summary": "Create new direct or group conversation",
        "responses": { "201": { "description": "Success" } }
      }
    },
    "/conversations/archived": {
      "get": {
        "tags": ["Conversations"],
        "summary": "Get hidden/archived conversations",
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/conversations/{conversationId}/messages": {
      "get": {
        "tags": ["Conversations"],
        "summary": "Get conversation messages",
        "parameters": [{ "name": "conversationId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/conversations/{conversationId}/seen": {
      "patch": {
        "tags": ["Conversations"],
        "summary": "Mark conversation as read",
        "parameters": [{ "name": "conversationId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/conversations/{conversationId}/hide": {
      "put": {
        "tags": ["Conversations"],
        "summary": "Hide a conversation",
        "parameters": [{ "name": "conversationId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/conversations/{conversationId}/unarchive": {
      "patch": {
        "tags": ["Conversations"],
        "summary": "Restore an archived conversation",
        "parameters": [{ "name": "conversationId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/conversations/{conversationId}/delete": {
      "delete": {
        "tags": ["Conversations"],
        "summary": "Delete conversation locally",
        "parameters": [{ "name": "conversationId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/conversations/{conversationId}/rename": {
      "patch": {
        "tags": ["Conversations"],
        "summary": "Rename group chat",
        "parameters": [{ "name": "conversationId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/conversations/{conversationId}/members": {
      "post": {
        "tags": ["Conversations"],
        "summary": "Add members to group",
        "parameters": [{ "name": "conversationId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/conversations/{conversationId}/leave": {
      "delete": {
        "tags": ["Conversations"],
        "summary": "Leave a group chat",
        "parameters": [{ "name": "conversationId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/messages/direct": {
      "post": {
        "tags": ["Messages"],
        "summary": "Send private direct message",
        "responses": { "201": { "description": "Success" } }
      }
    },
    "/messages/group": {
      "post": {
        "tags": ["Messages"],
        "summary": "Send message to group",
        "responses": { "201": { "description": "Success" } }
      }
    },
    "/messages/upload-image": {
      "post": {
        "tags": ["Messages"],
        "summary": "Upload image for a message",
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/messages/{messageId}": {
      "patch": {
        "tags": ["Messages"],
        "summary": "Edit an existing message content",
        "parameters": [{ "name": "messageId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Success" } }
      },
      "delete": {
        "tags": ["Messages"],
        "summary": "Delete or unsend a message",
        "parameters": [{ "name": "messageId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/messages/{messageId}/reactions": {
      "post": {
        "tags": ["Messages"],
        "summary": "React to a message with emoji",
        "parameters": [{ "name": "messageId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/friends": {
      "get": {
        "tags": ["Friends"],
        "summary": "Get accepted friends list",
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/friends/requests": {
      "get": {
        "tags": ["Friends"],
        "summary": "Get pending friend requests",
        "responses": { "200": { "description": "Success" } },
        "post": {
          "tags": ["Friends"],
          "summary": "Send a friend request",
          "responses": { "200": { "description": "Success" } }
        }
      }
    },
    "/friends/requests/{requestId}/accept": {
      "post": {
        "tags": ["Friends"],
        "summary": "Accept friend request",
        "parameters": [{ "name": "requestId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/friends/requests/{requestId}/decline": {
      "post": {
        "tags": ["Friends"],
        "summary": "Decline friend request",
        "parameters": [{ "name": "requestId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/friends/{friendId}": {
      "delete": {
        "tags": ["Friends"],
        "summary": "Remove a friend",
        "parameters": [{ "name": "friendId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/blocks": {
      "get": {
        "tags": ["Blocks"],
        "summary": "Get list of blocked users",
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/blocks/{userId}": {
      "post": {
        "tags": ["Blocks"],
        "summary": "Block a user",
        "parameters": [{ "name": "userId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Success" } }
      },
      "delete": {
        "tags": ["Blocks"],
        "summary": "Unblock a user",
        "parameters": [{ "name": "userId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/blocks/{userId}/status": {
      "get": {
        "tags": ["Blocks"],
        "summary": "Check if a user is blocked",
        "parameters": [{ "name": "userId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Success" } }
      }
    }
  }
}